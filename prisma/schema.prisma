generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  memberships         GroupMember[]
  paidExpenses        Expense[]            @relation("ExpensePayer")
  settlementsSent     Settlement[]         @relation("SettlementPayer")
  settlementsReceived Settlement[]         @relation("SettlementReceiver")
  expenseParticipants ExpenseParticipant[]
}

model Group {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
}

model GroupMember {
  id String @id @default(cuid())

  userId  String
  groupId String

  joinDate  DateTime
  leaveDate DateTime?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("INR")
  expenseDate DateTime
  splitType   String   @default("equal")
  notes       String?

  paidById String
  paidBy   User   @relation("ExpensePayer", fields: [paidById], references: [id])

  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  participants ExpenseParticipant[]
}

model ExpenseParticipant {
  id String @id @default(cuid())

  expenseId String
  userId    String

  shareAmount Decimal @db.Decimal(12, 2)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
}

model Settlement {
  id String @id @default(cuid())

  payerId    String
  receiverId String
  groupId    String

  amount Decimal  @db.Decimal(12, 2)
  date   DateTime @default(now())

  payer    User  @relation("SettlementPayer", fields: [payerId], references: [id])
  receiver User  @relation("SettlementReceiver", fields: [receiverId], references: [id])
  group    Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model ImportSession {
  id        String   @id @default(cuid())
  filename  String
  totalRows Int
  imported  Int
  skipped   Int
  createdAt DateTime @default(now())

  anomalies ImportAnomaly[]
}

model ImportAnomaly {
  id String @id @default(cuid())

  importSessionId String
  importSession   ImportSession @relation(fields: [importSessionId], references: [id], onDelete: Cascade)

  rowNumber     Int
  anomalyType   String
  originalValue String?
  fixedValue    String?
  actionTaken   String

  createdAt DateTime @default(now())
}
